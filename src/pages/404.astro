---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable — Antoine Pollet">
  <div class="flex flex-col items-start gap-4 py-12">
    <p class="font-mono text-sm text-neutral-500">404</p>
    <h1 class="text-4xl font-bold tracking-tight">Page introuvable</h1>
    <p class="text-neutral-600 dark:text-neutral-400">
      La page que tu cherches n'existe pas ou a été déplacée.
    </p>
    <a
      href="/"
      class="mt-4 inline-flex items-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-medium hover:border-neutral-900 dark:border-neutral-700 dark:hover:border-neutral-100"
    >
      Retour à l'accueil
    </a>
  </div>
</BaseLayout>
